{
  "version": 2,
  "builds": [
    { "src": "*.php", "use": "vercel-php@0.9.0" },
    { "src": "assets/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/login.php",
      "dest": "/login.php"
    },
    {
      "src": "/config.php",
      "dest": "/config.php"
    },
    {
      "src": "/((?!assets|login\\.php|config\\.php).*)",
      "dest": "/index.php"
    }
  ]
}