{
  "version": 2,
  "builds": [
    { "src": "api/index.php", "use": "vercel-php@0.9.0" },
    { "src": "*.php", "use": "vercel-php@0.9.0" },
    { "src": "signatures/**/*", "use": "@vercel/static" },
    { "src": "arsip/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/login", "dest": "/login.php" },
    { "src": "/register", "dest": "/register.php" },
    { "src": "/logout", "dest": "/logout.php" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}